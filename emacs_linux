;; Emacs settings on anacreon (Ubuntu 24.04 LTS running on MacBook Pro hardware.

;; Keybinding to refresh buffer. http://emacs.stackexchange.com/a/172
(global-set-key (kbd "C-c r")
		(lambda ()
		  (interactive)
		  (revert-buffer t t t)
		  (message "Refreshed buffer")))

